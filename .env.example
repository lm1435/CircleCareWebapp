# CircleCare Web Companion — copy to `.env` and fill in. NEVER commit `.env`.
# Only VITE_-prefixed public values belong here; they are bundled into the client.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=http://localhost:3000

# Optional — analytics is silently disabled when unset.
VITE_POSTHOG_KEY=

# Optional — RevenueCat Web Billing PUBLIC key. Web purchases are disabled when
# unset (free users see the in-app upgrade pointer). Use the SANDBOX key
# (rcb_sb_…) for local/dev so checkout runs in Stripe Test Mode (card 4242…);
# the production build uses the live key (rcb_…).
VITE_REVENUECAT_WEB_BILLING_KEY=
